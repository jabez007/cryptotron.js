{
  "name": "@jabez007/cryptotron-js",
  "version": "0.2.3",
  "description": "A TypeScript library for classical cryptography ciphers including Caesar, Vigenère, Substitution, and more.",
  "exports": "./src/index.ts",
  "tasks": {
    "dev": "deno test --watch ./src/index.ts"
  },
  "license": "GPL-3.0-only",
  "imports": {
    "@/": "./src/",
    "@types": "./src/types.ts",
    "@utils": "./src/utils/index.ts",
    "@std/assert": "jsr:@std/assert@1"
  },
  "lint": {
    "include": [
      "./src/"
    ],
    "exclude": [
      "./tests/**/*.spec.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": [
      "./src/"
    ],
    "exclude": [
      "./tests/**/*.spec.ts"
    ]
  },
  "nodeModulesDir": "auto",
  "exclude": [
    "./dist/"
  ],
  "publish": {
    "include": [
      "./src/",
      "README.md",
      "deno.json"
    ]
  }
}
